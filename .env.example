# LLM Configuration
LLM_MODEL_NAME=gpt-4o
LLM_MODEL_API_KEY=sk-proj-xxxx
LLM_MODEL_BASE_URL=https://api.openai.com/v1

# Embedding Configuration
EMBEDDING_MODEL_NAME=text-embedding-3-small
EMBEDDING_MODEL_API_KEY=sk-proj-xxxx
EMBEDDING_MODEL_BASE_URL=https://api.openai.com/v1
EMBEDDING_DIMENSION=1536

# Database Configuration
# Format: postgresql+psycopg://user:password@host:port/database
DATABASE_URL=postgresql+psycopg://postgres:openmemory123456@localhost:5432/ai_platform

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Flask Configuration
FLASK_APP=app
FLASK_ENV=development
SECRET_KEY=dev-secret-key-change-in-production
